{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Allow the app to spawn the bundled jfl-server sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/jfl-server", "sidecar": true }]
    }
  ]
}
