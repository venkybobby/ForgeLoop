# --- Upstream code lives in forge/ and loopy/ (committed in-tree). ---
# scripts/vendor.sh refreshes them from upstream, but they are tracked here so
# ForgeLoop is self-contained and runnable in access-scoped environments.
# Only the runtime state the subsystems generate is ignored:
/forge/.env.local
/forge/data/
/forge/extension/dist/

# --- Environment / secrets ---
.env
.env.local
*.local
config.env

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
build/
.next/
.turbo/
*.tsbuildinfo
# ...but forge/app/dist/index.html is a committed zero-build panel, not output:
!/forge/app/dist/
!/forge/app/dist/**

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Logs / runtime artifacts ---
*.log
logs/
runs/
traces/
*.sqlite
*.db
# Integration runtime state (audit trail, persisted run receipts):
.data/

# Local scratch build artifacts (prebuilt extension zips, sample traces):
scratchpad-ext/
scratchpad-trace/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
