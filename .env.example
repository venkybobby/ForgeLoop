# ===========================================================================
# ForgeLoop environment configuration
# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
# ===========================================================================

# --- General ---
FORGELOOP_ENV=development            # development | production
LOG_LEVEL=info                       # debug | info | warn | error

# --- Forge: ingestion server ---
# The server that receives recordings from the Chrome extension.
FORGE_SERVER_HOST=0.0.0.0
FORGE_SERVER_PORT=4000
# Where ingested recordings are stored before distillation.
FORGE_DATA_DIR=./.data/forge

# --- Forge: distillation harness ---
# LLM provider used to distill recordings into SKILL.md.
# ForgeLoop defaults to Anthropic Claude. Set the model id you want.
ANTHROPIC_API_KEY=
DISTILL_MODEL=claude-opus-4-8
# Output directory for generated SKILL.md files.
FORGE_SKILLS_DIR=./.data/skills

# --- Loopy: loop runtime ---
LOOPY_LIBRARY_DIR=./loopy/loop-library
# Where loop runs and their traces are written.
LOOPY_RUNS_DIR=./.data/runs

# --- Integration: dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=3000

# --- Integration: governance ---
# Require human approval before a loop run executes side-effecting actions.
GOVERNANCE_APPROVAL_REQUIRED=true
GOVERNANCE_AUDIT_DIR=./.data/audit
