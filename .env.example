# ===========================================================================
# ForgeLoop environment configuration
# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
# ===========================================================================

# --- General ---
FORGELOOP_ENV=development            # development | production
LOG_LEVEL=info                       # debug | info | warn | error

# --- Forge (Browser-BC / "Journey Forge Local") ---
# NOTE: Forge reads its OWN config from forge/.env.local (copied from
# forge/config.example.env by scripts/setup-forge.sh). Set your LLM key there:
#   SF_LLM_KEY=sk-ant-...        # used by the distillation harness
#   SF_DISTILL_MODEL=claude-opus-4-8
#   SF_CLASSIFY_MODEL=claude-haiku-4-5
# The values below are mirrored here for ForgeLoop's orchestration layer.
FORGE_SERVER_HOST=127.0.0.1
FORGE_SERVER_PORT=8099          # Forge server (JFL_PORT) default
# Forge keeps state under forge/data/ (buckets, traces, generated skills):
#   forge/data/harness/skills/<domain>/<capability>/SKILL.md

# --- Loopy: loop runtime ---
LOOPY_LIBRARY_DIR=./loopy/loop-library
# Where loop runs and their traces are written.
LOOPY_RUNS_DIR=./.data/runs

# --- Integration: dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=3000

# --- Integration: governance ---
# Require human approval before a loop run executes side-effecting actions.
GOVERNANCE_APPROVAL_REQUIRED=true
# Audit trail + run records now live in one SQLite file (supersedes the old
# GOVERNANCE_AUDIT_DIR / LOOPY_RUNS_DIR file dirs):
FORGELOOP_DB=./.data/forgeloop.db

# --- Integration: web app auth (see docs/auth.md) ---
# Precedence: OAuth > dev-login > token > open. Pick ONE.
#   OAuth (real per-user identity):
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# FORGELOOP_BASE_URL=https://your-app.fly.dev   # used to build the OAuth redirect
# FORGELOOP_ALLOWED_USERS=alice,bob             # optional GitHub-login allowlist
#   Shared-token gate (single tenant):
# FORGELOOP_TOKEN=
#   Dev login (NO password — local testing only):
# FORGELOOP_DEV_LOGIN=0
# Sign sessions so they survive restarts (set a long random value in prod):
# FORGELOOP_SESSION_SECRET=
# Rate limit per user per minute on run/approve (0 = off):
FORGELOOP_RATE_PER_MIN=30
